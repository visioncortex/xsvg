{
  "name": "@visioncortex/xsvg-viewer",
  "version": "0.1.1",
  "description": "Render xsvg — an XML graphics format that compiles to plain SVG — in the browser. Bundles the WASM compiler and a drop-in preview/slide-deck surface.",
  "type": "module",
  "license": "MIT",
  "author": "VisionCortex",
  "homepage": "https://xsvg.visioncortex.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visioncortex/xsvg.git",
    "directory": "packages/xsvg-viewer"
  },
  "keywords": [
    "svg",
    "xsvg",
    "wasm",
    "graphics",
    "text-layout",
    "gradient-mesh",
    "viewer"
  ],
  "sideEffects": [
    "**/element.*",
    "**/cdn.*",
    "**/xsvg.js"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./xsvg.js": "./dist/xsvg.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && vite build --config vite.embed.config.ts && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "opentype.js": "^2.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.6.3",
    "vite": "^8.1.0"
  }
}
